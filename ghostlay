#!/bin/bash

declare -g CONFIG_FILE="${GHOSTLAY_CONFIG:-$HOME/.config/ghostlay/config}"

die() {
    echo "ghostlay: $1" >&2
    exit 1
}

usage() {
    echo "Usage: ghostlay [--debug] [--layout <string>] <layout_name|ls>"
    exit 1
}

help_text() {
    cat <<'EOF'
ghostlay — automated Ghostty terminal layout tool

DESCRIPTION
  ghostlay sends keystrokes via wtype to split panes, navigate between
  them, resize, and run commands inside a Ghostty terminal. Layouts are
  defined as a sequence of tokens and executed one-by-one.

DEPENDENCY
  wtype — Wayland keyboard input simulator (required)

CONFIG
  ~/.config/ghostlay/config

  Format:
    delay = 1       # seconds between keystrokes (optional)
    bind = <t>:<p>  # override wtype params for token (optional)
    name = token "command" token ...

  Lines starting with '#' are ignored. Token order matters.

  Bind overrides the wtype arguments for a token, e.g.:
    bind = v:-M ctrl -M shift -k o -m shift -m ctrl
    bind = n:-M logo -M ctrl -k bracketright -m ctrl -m logo

  Example:
    # Two-pane dev setup
    dev = v p "nvim" n "cargo watch"

TOKENS (keys / commands)
  v    vertical split    (Ctrl+Shift+O)
  h    horizontal split  (Ctrl+Shift+E)
  n    next pane         (Super+Ctrl+])
  p    previous pane     (Super+Ctrl+[)
  rr   resize right      (Super+Ctrl+Alt+Shift+ArrowRight)
  rl   resize left       (Super+Ctrl+Alt+Shift+ArrowLeft)
  ru   resize up         (Super+Ctrl+Alt+Shift+ArrowUp)
  rd   resize down       (Super+Ctrl+Alt+Shift+ArrowDown)
  *    anything else is typed as a command followed by Enter; use quotes
       for multi-word commands, e.g. "cargo watch"

EXAMPLES
  ghostlay ls                                        list saved layouts
  ghostlay dev                                       run the "dev" layout
  ghostlay --layout 'v n "htop"'                     run an inline layout (no config needed)
  ghostlay --layout 'v n "nvim" n n "cargo watch"'   inline with multi-word cmd
  ghostlay --debug dev                               show token trace while running

NOTES
  - Must be run inside a Ghostty terminal (checks $GHOSTTY_RESOURCES_DIR
    or xterm-ghostty TERM value).
  - All keystrokes target the currently focused window.
  - Requires wtype tool.
EOF
    exit 0
}

declare -gA LAYOUTS
declare -gA BINDS
declare -g DELAY=0.5

generate_default_config() {
    local dir
    dir="$(dirname "$CONFIG_FILE")"
    mkdir -p "$dir"
    cat > "$CONFIG_FILE" <<'EOF'
delay = 0.5

bind = v:wtype -M ctrl -M shift -k o -m shift -m ctrl
bind = h:wtype -M ctrl -M shift -k e -m shift -m ctrl
bind = n:wtype -M logo -M ctrl -k bracketright -m ctrl -m logo
bind = p:wtype -M logo -M ctrl -k bracketleft -m ctrl -m logo
bind = rr:wtype -M logo -M ctrl -M alt -M shift -k Right -m shift -m alt -m ctrl -m logo
bind = rl:wtype -M logo -M ctrl -M alt -M shift -k Left -m shift -m alt -m ctrl -m logo
bind = ru:wtype -M logo -M ctrl -M alt -M shift -k Up -m shift -m alt -m ctrl -m logo
bind = rd:wtype -M logo -M ctrl -M alt -M shift -k Down -m shift -m alt -m ctrl -m logo
bind = cmd:wtype "$TOKEN" 2>/dev/null && wtype -k Return 2>/dev/null

# Example layouts
dev = "nvim ." v opencode rr rr p h rd rd p
quad = v h p p h p
EOF
}

read_config() {
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line#"${line%%[! ]*}"}"
        line="${line%"${line##*[! ]}"}"
        [[ -z "$line" || "$line" == "#"* ]] && continue
        if [[ "$line" =~ ^delay\ =\ ([0-9.]+)$ ]]; then
            DELAY="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^bind\ =\ ([^:]+):(.*)$ ]]; then
            local token="${BASH_REMATCH[1]}"
            local params="${BASH_REMATCH[2]}"
            params="${params#"${params%%[! ]*}"}"
            params="${params%"${params##*[! ]}"}"
            BINDS["$token"]="$params"
        elif [[ "$line" == *" = "* ]]; then
            local name="${line%% = *}"
            local layout="${line#* = }"
            LAYOUTS["$name"]="$layout"
        fi
    done < "$CONFIG_FILE"
}

main() {
    local DEBUG= LAYOUT_STR=
    [[ ! -f "$CONFIG_FILE" ]] && generate_default_config
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --debug) DEBUG=1; shift ;;
            --layout) LAYOUT_STR="$2"; shift 2 ;;
            -h|--help) help_text ;;
            *) break ;;
        esac
    done
    local cmd="$1"

    if [[ -z "$LAYOUT_STR" ]]; then
        [[ -z "$cmd" ]] && usage
        read_config
        if [[ "$cmd" == "ls" ]]; then
            echo "Available layouts:"; local name
            for name in "${!LAYOUTS[@]}"; do echo "  $name"; done; exit 0
        fi
        local layout="${LAYOUTS[$cmd]}"
        [[ -z "$layout" ]] && die "layout not found: $cmd (use 'ghostlay ls' to list)"
    else
        read_config
        local layout="$LAYOUT_STR"
        local cmd="(inline)"
    fi

    [[ -z "$GHOSTTY_RESOURCES_DIR" && "$TERM" != "xterm-ghostty" ]] && die "not running in a Ghostty terminal"
    local tokens=()
    eval "tokens=($layout)"
    [[ ${#tokens[@]} -eq 0 ]] && die "no tokens in layout: $layout"
    [[ -n "$DEBUG" ]] && echo "Tokens: ${tokens[*]}" >&2
    local token
    for token in "${tokens[@]}"; do
        TOKEN="$token"
        if [[ -n "${BINDS[$token]:-}" ]]; then
            [[ -n "$DEBUG" ]] && echo "  bind $token: ${BINDS[$token]}" >&2
            eval "${BINDS[$token]}"
        elif [[ -n "${BINDS[cmd]:-}" ]]; then
            [[ -n "$DEBUG" ]] && echo "  cmd $token: ${BINDS[cmd]}" >&2
            eval "${BINDS[cmd]}"
        else
            die "no binding for token: $token"
        fi
        sleep "$DELAY"
    done
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
:
